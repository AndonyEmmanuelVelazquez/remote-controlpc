{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "remote-control-signaling",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOM",
        "class_name": "Room"
      }
    ]
  },
  // SQLite-backed DO class -> required to stay on the Workers Free plan.
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Room"]
    }
  ]
}
