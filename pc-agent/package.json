{
  "name": "remote-control-pc-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Electron host agent: shares screen over WebRTC and injects remote input.",
  "main": "dist/main.js",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && node scripts/start.mjs",
    "pack": "npm run build && electron-packager . RemoteControlPCAgent --platform=win32 --arch=x64 --out=release --overwrite --ignore=^/release --ignore=^/src",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.0"
  },
  "devDependencies": {
    "@electron/packager": "^18.3.0",
    "@types/node": "^22.0.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.remotecontrol.pcagent",
    "productName": "Remote Control PC Agent",
    "files": ["dist/**/*", "package.json"],
    "extraMetadata": { "main": "dist/main.js" },
    "directories": { "output": "release" },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
